rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /matches/{matchId} {
      allow read, write: if request.auth != null;
    }

    match /word-rush-matches/{matchId} {
      allow read, write: if request.auth != null;
    }

    match /word-rush-leaderboard/{entryId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /word-rush-word-reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /word-rush-users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      match /friends/{friendUid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /word-rush-friend-rivals/{pairId} {
      // resource is null when the doc does not exist yet (e.g. first match in a transaction).
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.uids);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.uids;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.uids;
      allow delete: if false;
    }

    match /word-rush-game-requests/{requestId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.status == 'pending';
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.toUid
            || request.auth.uid == resource.data.fromUid);
      allow delete: if false;
    }
  }
}
